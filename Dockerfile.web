FROM python:3.11-slim as backend

WORKDIR /app

# Install system dependencies
RUN apt-get update && apt-get install -y --no-install-recommends \
    curl \
    gnupg \
    && rm -rf /var/lib/apt/lists/*

# Install Docker CLI (for sibling container management)
RUN curl -fsSL https://get.docker.com -o get-docker.sh && sh get-docker.sh

# Install Python dependencies
COPY requirements.txt .
# Add FastAPI dependencies with bcrypt support
RUN pip install --no-cache-dir -r requirements.txt && \
    pip install --no-cache-dir fastapi uvicorn sqlalchemy psycopg2-binary python-jose[cryptography] passlib[bcrypt] python-multipart docker bcrypt

# Copy Backend Code
COPY backend /app/backend
COPY hypothesis_validation.py /app/hypothesis_validation.py

# --- Frontend Build Stage ---
FROM node:18 as frontend-build
WORKDIR /frontend
COPY frontend/package.json frontend/package-lock.json* ./
RUN npm install
COPY frontend .
RUN npm run build

# --- Final Stage ---
FROM backend
COPY --from=frontend-build /frontend/dist /app/frontend/dist

# Create output directory
RUN mkdir -p /app/outputs

# Expose port
EXPOSE 8000

# Run FastAPI
CMD ["uvicorn", "backend.app.main:app", "--host", "0.0.0.0", "--port", "8000"]
